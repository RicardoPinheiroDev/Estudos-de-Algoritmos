Algoritmo "Pratica_O1_Operadores"
// Data atual  : 23/06/2026
Var
   N1, N2, Soma: Inteiro


Inicio
      Escreva("Insira o primeiro numero: ")
      Leia(N1)
      
      Escreva("Insira o segundo numero: ")
      Leia(N2)
      
      Soma <- N1 + N2
      
      Escreva("A soma entre", N1, " e" ,N2, " e igual a", Soma)

Fimalgoritmo