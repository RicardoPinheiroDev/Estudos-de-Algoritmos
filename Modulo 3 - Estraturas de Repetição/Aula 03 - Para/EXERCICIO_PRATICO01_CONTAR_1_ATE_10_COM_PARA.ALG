Algoritmo "EXERCICIO_PRATICO01_CONTAR_1_ATE_10_COM_PARA"
// Data atual  : 01/07/2026
Var
   contador: Inteiro


Inicio
      /Para contador <- 1 ate 10 passo 1 faca
      // Para contador <- 1 ate 10 passo 2 faca
      // Para contador <- 10 ate 1 passo -1 faca
           Escreva(contador)
      FimPara


Fimalgoritmo