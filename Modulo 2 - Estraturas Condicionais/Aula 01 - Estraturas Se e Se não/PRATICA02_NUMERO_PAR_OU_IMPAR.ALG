Algoritmo "PRATICA01_NUMERO_PAR_OU_IMPAR"
// Data atual  : 25/06/2026
Var
   N: Inteiro

Inicio
      Escreva("Insira um numero qualquer: ")
      Leia(N)
      
      Se(N % 2 = 0) entao
           Escreval("O numero",N, " e par")
      senao
           EscrevaL("O numero ",N, " e impar")
     FimSe
Fimalgoritmo